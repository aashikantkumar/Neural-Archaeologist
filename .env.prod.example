# ──────────────────────────────────────────────────────────────────────────────
# .env.prod.example — copy to .env.prod and fill in real values
# NEVER commit .env.prod to git
# ──────────────────────────────────────────────────────────────────────────────

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN_NAME=your-domain.com

# ── PostgreSQL (Docker container) ─────────────────────────────────────────────
# If using AWS RDS, remove the db service from docker-compose.prod.yml
# and set DATABASE_URL to the RDS endpoint below.
POSTGRES_DB=neural_archaeologist
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Backend app ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:CHANGE_ME_strong_password_here@db:5432/neural_archaeologist
# For AWS RDS use:
# DATABASE_URL=postgresql://USER:PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/neural_archaeologist

GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
SERPAPI_API_KEY=xxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx   # optional

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_secure_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
