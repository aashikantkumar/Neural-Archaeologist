# ============================
# Backend Configuration
# ============================

# Database (MongoDB connection string)
DATABASE_URL=mongodb://localhost:27017/neural_archaeologist

# API Keys
GROQ_API_KEY=your_groq_api_key_here
SERPAPI_API_KEY=your_serpapi_api_key_here
