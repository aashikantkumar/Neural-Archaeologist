# Database
DATABASE_URL=postgresql://user:password@localhost:5432/neural_archaeologist

# API Keys
GROQ_API_KEY=your_groq_api_key_here
SERPAPI_API_KEY=your_serpapi_key_here

# JWT Secret (generate a random 32+ character string)
SECRET_KEY=your-super-secret-jwt-key-min-32-chars

# App Settings
DEBUG=False

# Optional: GitHub Personal Access Token (increases rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=your_github_token_here

# CORS Origins (production URLs - update with your deployment domains)
ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,http://localhost:5173